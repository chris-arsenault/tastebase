# Database (shared platform RDS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tastebase
DB_USERNAME=tastebase_app
DB_PASSWORD=localdev

# Cognito (shared platform pool)
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_DOMAIN=https://auth.ahara.io
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
COGNITO_CLIENT_ID=exampleclientid

# S3 media
MEDIA_BUCKET=tastebase-media

# URLs
API_BASE_URL=https://api.tastebase.ahara.io
APP_BASE_URL=https://tastebase.ahara.io

# Processing (tastings-api only)
PROCESSING_FUNCTION_NAME=tastebase-processing

# Bedrock (processing only)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
